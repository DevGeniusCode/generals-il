{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|whatsapp|telegram|discord|facebook|twitter|slack).*"
        }
      ],
      "destination": "/api/bot-proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}